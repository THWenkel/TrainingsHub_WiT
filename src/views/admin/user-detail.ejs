<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/admin/users">Users</a></li>
    <li class="breadcrumb-item active"><%= user.name %></li>
  </ol>
</nav>

<div class="row g-4">
  <!-- User Info -->
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header"><i class="bi bi-person-circle me-1"></i>User Details</div>
      <div class="card-body">
        <dl class="row mb-3">
          <dt class="col-sm-4">Name</dt>
          <dd class="col-sm-8"><%= user.name %></dd>
          <dt class="col-sm-4">Email</dt>
          <dd class="col-sm-8"><%= user.email %></dd>
          <dt class="col-sm-4">Role</dt>
          <dd class="col-sm-8">
            <span class="badge <%= user.role === 'admin' ? 'bg-danger' : 'bg-secondary' %>"><%= user.role %></span>
          </dd>
          <dt class="col-sm-4">Joined</dt>
          <dd class="col-sm-8"><%= user.created_at.substring(0, 10) %></dd>
        </dl>

        <!-- Change Role -->
        <form action="/admin/users/<%= user.id %>/role" method="POST" class="border-top pt-3">
          <%- include('../partials/csrf') %>
          <label class="form-label fw-semibold">Change Role</label>
          <div class="d-flex gap-2">
            <select name="role" class="form-select form-select-sm">
              <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
              <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
          </div>
        </form>

        <!-- Delete User -->
        <form action="/admin/users/<%= user.id %>/delete" method="POST" class="mt-3"
              onsubmit="return confirm('Delete this user? All their data will be removed.');">
          <%- include('../partials/csrf') %>
          <button type="submit" class="btn btn-sm btn-outline-danger w-100">
            <i class="bi bi-trash me-1"></i>Delete User
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Registrations -->
  <div class="col-lg-8">
    <div class="card shadow-sm mb-4">
      <div class="card-header"><i class="bi bi-clipboard-check me-1"></i>Registrations (<%= registrations.length %>)</div>
      <% if (registrations.length === 0) { %>
        <div class="card-body text-muted text-center py-3">No registrations yet.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr><th>Training</th><th>Type</th><th>Date</th><th>Status</th></tr>
            </thead>
            <tbody>
              <% registrations.forEach(function(reg) { %>
              <tr>
                <td><a href="/trainings/<%= reg.training_id %>"><%= reg.title %></a></td>
                <td><span class="badge <%= reg.type === 'webinar' ? 'bg-info text-dark' : 'bg-success' %>"><%= reg.type %></span></td>
                <td><%= reg.date %></td>
                <td><span class="badge <%= reg.status === 'confirmed' ? 'bg-success' : reg.status === 'cancelled' ? 'bg-secondary' : 'bg-warning text-dark' %>"><%= reg.status %></span></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Access Management -->
    <div class="card shadow-sm">
      <div class="card-header"><i class="bi bi-shield-lock me-1"></i>Training Access Management</div>
      <div class="card-body">
        <p class="text-muted small mb-3">Grant or revoke access to specific trainings for this user (overrides capacity limits).</p>
        <% if (allTrainings.length === 0) { %>
          <p class="text-muted">No trainings available.</p>
        <% } else { %>
          <form action="/admin/users/<%= user.id %>/access" method="POST">
            <%- include('../partials/csrf') %>
            <div class="row g-2 mb-3">
              <div class="col-md-6">
                <select name="training_id" class="form-select" required>
                  <option value="">Select Training…</option>
                  <% allTrainings.forEach(function(t) { %>
                    <option value="<%= t.id %>"><%= t.date %> – <%= t.title %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-4">
                <select name="access_granted" class="form-select">
                  <option value="1">Grant Access</option>
                  <option value="0">Revoke Access</option>
                </select>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Save</button>
              </div>
            </div>
          </form>

          <!-- Current access list -->
          <% const accessEntries = Object.entries(accessMap); %>
          <% if (accessEntries.length > 0) { %>
            <h6 class="mt-3 text-muted small text-uppercase">Current Access Grants</h6>
            <div class="table-responsive">
              <table class="table table-sm mb-0">
                <thead class="table-light"><tr><th>Training</th><th>Access</th></tr></thead>
                <tbody>
                  <% accessEntries.forEach(function(entry) {
                      const tid = entry[0];
                      const granted = entry[1];
                      const t = allTrainings.find(x => x.id == tid);
                  %>
                  <tr>
                    <td><%= t ? t.title : 'Unknown' %></td>
                    <td>
                      <span class="badge <%= granted ? 'bg-success' : 'bg-danger' %>">
                        <%= granted ? 'Granted' : 'Revoked' %>
                      </span>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
