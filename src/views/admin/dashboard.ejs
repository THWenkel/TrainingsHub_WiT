<%- include('../partials/header') %>

<h1 class="h3 mb-4"><i class="bi bi-speedometer2 me-2 text-primary"></i>Admin Dashboard</h1>

<div class="row g-4 mb-4">
  <div class="col-sm-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center p-3 h-100">
      <div class="card-body">
        <i class="bi bi-people display-4 text-primary mb-2"></i>
        <h2 class="fw-bold"><%= stats.userCount %></h2>
        <p class="text-muted mb-0">Total Users</p>
      </div>
      <div class="card-footer bg-transparent border-0">
        <a href="/admin/users" class="btn btn-outline-primary btn-sm">Manage Users</a>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center p-3 h-100">
      <div class="card-body">
        <i class="bi bi-mortarboard display-4 text-success mb-2"></i>
        <h2 class="fw-bold"><%= stats.trainingCount %></h2>
        <p class="text-muted mb-0">Trainings</p>
      </div>
      <div class="card-footer bg-transparent border-0">
        <a href="/trainings" class="btn btn-outline-success btn-sm">View All</a>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center p-3 h-100">
      <div class="card-body">
        <i class="bi bi-clipboard-check display-4 text-info mb-2"></i>
        <h2 class="fw-bold"><%= stats.registrationCount %></h2>
        <p class="text-muted mb-0">Active Registrations</p>
      </div>
      <div class="card-footer bg-transparent border-0">
        <a href="/admin/registrations" class="btn btn-outline-info btn-sm">View All</a>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center p-3 h-100">
      <div class="card-body">
        <i class="bi bi-hourglass-split display-4 text-warning mb-2"></i>
        <h2 class="fw-bold"><%= stats.pendingCount %></h2>
        <p class="text-muted mb-0">Pending Registrations</p>
      </div>
      <div class="card-footer bg-transparent border-0">
        <a href="/admin/registrations?status=pending" class="btn btn-outline-warning btn-sm">Review</a>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-plus-circle me-1"></i>Quick Actions</span>
      </div>
      <div class="card-body d-flex flex-column gap-2">
        <a href="/trainings/new" class="btn btn-outline-primary"><i class="bi bi-calendar-plus me-2"></i>Create New Training</a>
        <a href="/admin/registrations?status=pending" class="btn btn-outline-warning"><i class="bi bi-hourglass me-2"></i>Review Pending Registrations</a>
        <a href="/admin/users" class="btn btn-outline-secondary"><i class="bi bi-people me-2"></i>Manage Users & Access</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
