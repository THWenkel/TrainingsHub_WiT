<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/trainings">Trainings</a></li>
    <li class="breadcrumb-item active"><%= training ? 'Edit Training' : 'New Training' %></li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-header">
        <h4 class="mb-0">
          <i class="bi <%= training ? 'bi-pencil-square' : 'bi-plus-circle' %> me-2"></i>
          <%= training ? 'Edit Training' : 'Create New Training' %>
        </h4>
      </div>
      <div class="card-body p-4">
        <form action="<%= training ? '/trainings/' + training.id : '/trainings' %>" method="POST">
          <%- include('../partials/csrf') %>
          <div class="row g-3">
            <div class="col-12">
              <label for="title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="title" name="title"
                     value="<%= training ? training.title : '' %>" required maxlength="200">
            </div>

            <div class="col-md-6">
              <label for="type" class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
              <select class="form-select" id="type" name="type" required>
                <option value="training" <%= (!training || training.type === 'training') ? 'selected' : '' %>>Training</option>
                <option value="webinar" <%= (training && training.type === 'webinar') ? 'selected' : '' %>>Webinar</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="trainer" class="form-label fw-semibold">Trainer / Speaker</label>
              <input type="text" class="form-control" id="trainer" name="trainer"
                     value="<%= training ? training.trainer : '' %>" maxlength="100">
            </div>

            <div class="col-md-4">
              <label for="date" class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="date" name="date"
                     value="<%= training ? training.date : '' %>" required>
            </div>

            <div class="col-md-4">
              <label for="time" class="form-label fw-semibold">Start Time <span class="text-danger">*</span></label>
              <input type="time" class="form-control" id="time" name="time"
                     value="<%= training ? training.time : '' %>" required>
            </div>

            <div class="col-md-4">
              <label for="duration_minutes" class="form-label fw-semibold">Duration (minutes) <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="duration_minutes" name="duration_minutes"
                     value="<%= training ? training.duration_minutes : 60 %>" min="1" required>
            </div>

            <div class="col-12">
              <label for="location" class="form-label fw-semibold">Location / Meeting Link</label>
              <input type="text" class="form-control" id="location" name="location"
                     value="<%= training ? training.location : '' %>" maxlength="200"
                     placeholder="e.g. Conference Room A or https://zoom.us/j/...">
            </div>

            <div class="col-md-6">
              <label for="max_participants" class="form-label fw-semibold">Max Participants <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="max_participants" name="max_participants"
                     value="<%= training ? training.max_participants : 20 %>" min="1" required>
            </div>

            <div class="col-md-4">
              <label for="price" class="form-label fw-semibold">Price <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="price" name="price"
                     value="<%= training ? training.price : 0 %>" min="0" step="0.01" required>
            </div>

            <div class="col-md-2">
              <label for="currency" class="form-label fw-semibold">Currency</label>
              <select class="form-select" id="currency" name="currency">
                <option value="EUR" <%= (!training || training.currency === 'EUR') ? 'selected' : '' %>>EUR</option>
                <option value="USD" <%= (training && training.currency === 'USD') ? 'selected' : '' %>>USD</option>
                <option value="GBP" <%= (training && training.currency === 'GBP') ? 'selected' : '' %>>GBP</option>
              </select>
            </div>

            <div class="col-12">
              <label for="description" class="form-label fw-semibold">Description</label>
              <textarea class="form-control" id="description" name="description" rows="4" maxlength="2000"><%= training ? training.description : '' %></textarea>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i><%= training ? 'Save Changes' : 'Create Training' %>
            </button>
            <a href="/trainings<%= training ? '/' + training.id : '' %>" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
