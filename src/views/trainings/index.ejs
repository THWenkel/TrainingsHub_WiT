<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3"><i class="bi bi-list-ul me-2 text-primary"></i>Trainings Overview</h1>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <a href="/trainings/new" class="btn btn-primary">
      <i class="bi bi-plus-circle me-1"></i>New Training
    </a>
  <% } %>
</div>

<!-- Filters -->
<form class="row g-2 mb-4" method="GET" action="/trainings">
  <div class="col-md-5">
    <input type="text" class="form-control" name="search" placeholder="Search by title, trainer..." value="<%= search %>">
  </div>
  <div class="col-md-3">
    <select class="form-select" name="type">
      <option value="">All Types</option>
      <option value="training" <%= type === 'training' ? 'selected' : '' %>>Training</option>
      <option value="webinar" <%= type === 'webinar' ? 'selected' : '' %>>Webinar</option>
    </select>
  </div>
  <div class="col-md-2">
    <button type="submit" class="btn btn-outline-secondary w-100">
      <i class="bi bi-search me-1"></i>Filter
    </button>
  </div>
  <% if (search || type) { %>
  <div class="col-md-2">
    <a href="/trainings" class="btn btn-outline-danger w-100">
      <i class="bi bi-x-circle me-1"></i>Clear
    </a>
  </div>
  <% } %>
</form>

<% if (trainings.length === 0) { %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-calendar-x display-4 d-block mb-3"></i>
    <p class="lead">No trainings found.</p>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a href="/trainings/new" class="btn btn-primary mt-2">Add a Training</a>
    <% } %>
  </div>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
    <% trainings.forEach(function(t) { %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span class="badge <%= t.type === 'webinar' ? 'bg-info text-dark' : 'bg-success' %>">
              <i class="bi <%= t.type === 'webinar' ? 'bi-camera-video' : 'bi-people' %> me-1"></i>
              <%= t.type.charAt(0).toUpperCase() + t.type.slice(1) %>
            </span>
            <% if (t.price > 0) { %>
              <span class="fw-bold text-primary"><%= t.price.toFixed(2) %> <%= t.currency %></span>
            <% } else { %>
              <span class="badge bg-secondary">Free</span>
            <% } %>
          </div>
          <div class="card-body">
            <h5 class="card-title"><%= t.title %></h5>
            <p class="card-text text-muted small mb-2">
              <i class="bi bi-calendar-date me-1"></i><%= t.date %> at <%= t.time %>
              &nbsp;|&nbsp;
              <i class="bi bi-clock me-1"></i><%= t.duration_minutes %> min
            </p>
            <% if (t.trainer) { %>
              <p class="card-text small mb-1"><i class="bi bi-person-badge me-1"></i><%= t.trainer %></p>
            <% } %>
            <% if (t.location) { %>
              <p class="card-text small mb-2"><i class="bi bi-geo-alt me-1"></i><%= t.location %></p>
            <% } %>
            <% if (t.description) { %>
              <p class="card-text small text-muted"><%= t.description.length > 100 ? t.description.substring(0, 100) + '…' : t.description %></p>
            <% } %>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
              <i class="bi bi-people me-1"></i><%= t.registered_count %> / <%= t.max_participants %>
              <% const pct = Math.round((t.registered_count / t.max_participants) * 100); %>
              <div class="progress mt-1" style="height:4px;width:80px;">
                <div class="progress-bar <%= pct >= 90 ? 'bg-danger' : pct >= 60 ? 'bg-warning' : 'bg-success' %>"
                     style="width:<%= pct %>%"></div>
              </div>
            </small>
            <a href="/trainings/<%= t.id %>" class="btn btn-outline-primary btn-sm">
              <% if (registrationMap[t.id] && registrationMap[t.id] !== 'cancelled') { %>
                <i class="bi bi-check-circle me-1"></i>Registered
              <% } else { %>
                View Details
              <% } %>
            </a>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/footer') %>
