<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3"><i class="bi bi-credit-card me-2 text-primary"></i>Billing Information</h1>
  <a href="/billing/edit" class="btn btn-primary">
    <i class="bi bi-pencil me-1"></i><%= billing ? 'Edit' : 'Add Billing Info' %>
  </a>
</div>

<% if (!billing) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5 text-muted">
      <i class="bi bi-credit-card-2-back display-4 d-block mb-3"></i>
      <p class="lead">No billing information saved yet.</p>
      <p>Please add your billing details to register for paid trainings.</p>
      <a href="/billing/edit" class="btn btn-primary mt-2">
        <i class="bi bi-plus-circle me-1"></i>Add Billing Information
      </a>
    </div>
  </div>
<% } else { %>
  <div class="row g-4">
    <div class="col-md-6">
      <div class="card shadow-sm h-100">
        <div class="card-header fw-semibold"><i class="bi bi-person-vcard me-1"></i>Contact & Address</div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-5">Full Name</dt>
            <dd class="col-sm-7"><%= billing.full_name %></dd>
            <% if (billing.company) { %>
            <dt class="col-sm-5">Company</dt>
            <dd class="col-sm-7"><%= billing.company %></dd>
            <% } %>
            <dt class="col-sm-5">Address</dt>
            <dd class="col-sm-7"><%= billing.address %></dd>
            <dt class="col-sm-5">City</dt>
            <dd class="col-sm-7"><%= billing.city %></dd>
            <dt class="col-sm-5">ZIP Code</dt>
            <dd class="col-sm-7"><%= billing.zip_code %></dd>
            <dt class="col-sm-5">Country</dt>
            <dd class="col-sm-7"><%= billing.country %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card shadow-sm h-100">
        <div class="card-header fw-semibold"><i class="bi bi-bank me-1"></i>Payment Details</div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-5">Payment Method</dt>
            <dd class="col-sm-7">
              <% if (billing.payment_method === 'invoice') { %>
                <span class="badge bg-secondary">Invoice</span>
              <% } else if (billing.payment_method === 'bank_transfer') { %>
                <span class="badge bg-info text-dark">Bank Transfer</span>
              <% } else { %>
                <span class="badge bg-primary">Credit Card</span>
              <% } %>
            </dd>
            <% if (billing.iban) { %>
            <dt class="col-sm-5">IBAN</dt>
            <dd class="col-sm-7 font-monospace"><%= billing.iban %></dd>
            <% } %>
            <dt class="col-sm-5">Last Updated</dt>
            <dd class="col-sm-7"><%= billing.updated_at ? billing.updated_at.substring(0, 10) : '—' %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
